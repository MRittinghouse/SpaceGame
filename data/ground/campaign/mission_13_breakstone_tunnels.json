    "story_triggers": [
        {
            "x": 13, "y": 20,
            "type": "atmosphere",
            "text": "The access shaft drops away beneath reinforced struts. Rock dust hangs in recycled air that tastes of iron and machine oil. Hand-painted signs in Union blue mark depth levels. You're heading where visitors don't go."
        },
        {
            "x": 15, "y": 16,
            "type": "atmosphere",
            "text": "A security station built from welded freight containers. Union insignia above the gate, shift rosters on a clipboard. The guards here know every face that works these tunnels. Yours isn't one of them."
        },
        {
            "x": 12, "y": 10,
            "type": "atmosphere",
            "text": "The main gallery opens into a cathedral of carved rock. Heavy drilling rigs sit idle between shifts, ventilation fans humming where the machinery should roar. Thousands of tons of ore have passed through here — Breakstone's lifeblood, cut from the asteroid one blast at a time."
        },
        {
            "x": 1, "y": 8,
            "type": "atmosphere",
            "text": "The worked stone gives way to rough-cut rock. The air is colder here, and the ventilation barely reaches. Old mining rails disappear into darkness ahead. These tunnels haven't seen a work crew in years."
        },
        {
            "x": 3, "y": 5,
            "type": "atmosphere",
            "text": "Something shifts in the darkness ahead. A faint light — chemical, not electric — flickers beyond a sealed door. Someone lives down here by choice. Someone who doesn't want to be found."
        }
    ]
}
