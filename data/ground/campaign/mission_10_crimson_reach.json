    "story_triggers": [
        {
            "x": 5, "y": 17,
            "type": "atmosphere",
            "text": "Wrecker's Outpost doesn't look like much from the airlock  -- welded hull plates, exposed conduit, a hand-painted sign reading WELCOME in six languages. But the air recyclers work, and nobody asks your name."
        },
        {
            "x": 12, "y": 11,
            "type": "atmosphere",
            "text": "The corridor opens into Wrecker's Market. Cargo containers welded end-to-end serve as vendor stalls, hull plating in three different alloys forming the walls. Everything here was something else once. Nobody asks where it came from."
        },
        {
            "x": 1, "y": 9,
            "type": "atmosphere",
            "text": "Loose deck plating shifts and rings underfoot  -- mismatched panels from salvaged freighters, not quite flush. Each step announces itself to the corridor."
        },
        {
            "x": 12, "y": 4,
            "type": "atmosphere",
            "text": "The market smells give way to solder flux and hydraulic fluid. Tools hang on magnetic strips along walls of mismatched alloy panels. Someone runs a serious operation back here."
        }
    ]
